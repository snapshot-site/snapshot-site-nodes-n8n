{
    "name": "n8n-nodes-snapshot-site",
    "version": "0.1.1",
    "description": "n8n community node for the Snapshot Site API — website screenshots, AI-powered page analysis, and visual diff comparisons.",
    "license": "MIT",
    "homepage": "https://snapshot-site.com",
    "keywords": [
        "n8n-community-node-package",
        "snapshot-site",
        "screenshot",
        "screenshot-api",
        "visual-diff",
        "visual-regression"
    ],
    "author": {
        "name": "Snapshot Site",
        "email": "support@snapshot-site.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/snapshot-site/snapshot-site-nodes-n8n.git"
    },
    "bugs": {
        "url": "https://github.com/snapshot-site/snapshot-site-nodes-n8n/issues"
    },
    "engines": {
        "node": ">=20.9.0"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "test": "jest",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/SnapshotSiteApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/SnapshotSite/SnapshotSite.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "@types/jest": "^29.5.14",
        "eslint": "9.32.0",
        "jest": "^29.7.0",
        "n8n-workflow": "*",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "ts-jest": "^29.2.5",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
